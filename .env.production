# ============================================
# ArthaA Production Environment
# Copy this to .env on your VPS and fill in all values
# ============================================

# Your domain (e.g. arthaa.example.com or your VPS IP for testing)
DOMAIN=yourdomain.com

# Email for Let's Encrypt SSL certificate notifications
EMAIL=your@email.com

# Database
DB_USER=arthaa_user
DB_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
DB_NAME=arthaa

# Auth — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=GENERATE_AND_PASTE_A_LONG_RANDOM_KEY_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI (Ollama) — deepseek-r1:7b requires ~8GB RAM on CPU
OLLAMA_MODEL=deepseek-r1:7b

# File uploads
MAX_FILE_SIZE_MB=10
